<configuration>
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender"><encoder class="net.logstash.logback.encoder.LogstashEncoder"/></appender>
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender"><file>logs/ms-auth.json</file><rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy"><fileNamePattern>logs/ms-auth-%d{yyyy-MM-dd}.json</fileNamePattern><maxHistory>7</maxHistory></rollingPolicy><encoder class="net.logstash.logback.encoder.LogstashEncoder"/></appender>
    <root level="INFO"><appender-ref ref="JSON_CONSOLE"/><appender-ref ref="JSON_FILE"/></root>
</configuration>
